# Environment Configuration (dev/prod)
ENVIRONMENT=dev
PROJECT_NAME=KnowledgeOS

# Database URL Configuration
DATABASE_URL=postgresql://postgres:postgrespassword@localhost:5432/knowledgeos

# Security Configuration
# Generate a secure key using: openssl rand -hex 32
JWT_SECRET_KEY=yoursecretkeyhere_change_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Gemini AI Configuration
# Obtain an API key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Storage Configuration (local/s3)
STORAGE_PROVIDER=local
LOCAL_STORAGE_PATH=storage/uploads

# AWS S3 / Cloudflare R2 Configurations (Optional, required if STORAGE_PROVIDER=s3)
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1
S3_BUCKET_NAME=your_s3_bucket_name
S3_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com # Set for Cloudflare R2

# CORS Configurations (Comma separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
